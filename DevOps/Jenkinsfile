pipeline {
    agent any

    environment {
        DOCKER_HUB_CREDENTIALS = credentials('docker-hub-credentials')
        DOCKERHUB_USER         = "binetuuu"
        BACKEND_IMAGE          = "binetuuu/portfolio-backend"
        FRONTEND_IMAGE         = "binetuuu/portfolio-frontend"
        SONAR_HOST_URL         = "http://172.17.0.3:9000"
        SONAR_TOKEN            = credentials('sonarqube-token')
        KUBECONFIG             = credentials('kubeconfig-portfolio')
        K8S_NAMESPACE          = "portfolio"
        TF_DIR                 = "DevOps/terraform/k8s-deploy"
    }

    stages {

        // ─────────────────────────────────────────
        // Clone du dépôt
        // ─────────────────────────────────────────
        stage('Clone Repository') {
            steps {
                git branch: 'main',
                    credentialsId: 'github_creds',
                    url: 'https://github.com/Binetuuu/Portfolio_Binetou.git'
            }
        }

        // ─────────────────────────────────────────
        // Analyse SonarQube
        // ─────────────────────────────────────────
        stage('SonarQube Analysis') {
            steps {
                dir('DevOps') {
                    withSonarQubeEnv('SonarQube') {
                        sh """
                            ${tool 'SonarScanner'}/bin/sonar-scanner \
                              -Dsonar.projectKey=portfolio-project \
                              -Dsonar.sources=Backend \
                              -Dsonar.exclusions=Backend/node_modules/**,Backend/.git/**,Backend/dist/**,Backend/coverage/** \
                              -Dsonar.host.url=${SONAR_HOST_URL} \
                              -Dsonar.token=${SONAR_TOKEN}
                        """
                    }
                }
            }
        }

        // ─────────────────────────────────────────
        // Quality Gate
        // ─────────────────────────────────────────
        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        // ─────────────────────────────────────────
        // Build des images Docker
        // ─────────────────────────────────────────
        stage('Build Backend') {
            steps {
                dir('DevOps/Backend') {
                    sh 'docker build -t $BACKEND_IMAGE:${BUILD_NUMBER} -t $BACKEND_IMAGE:latest .'
                }
            }
        }

        stage('Build Frontend') {
            steps {
                dir('DevOps/Frontend') {
                    sh 'docker build -t $FRONTEND_IMAGE:${BUILD_NUMBER} -t $FRONTEND_IMAGE:latest .'
                }
            }
        }

        // ─────────────────────────────────────────
        // Push vers Docker Hub
        // ─────────────────────────────────────────
        stage('Push to Docker Hub') {
            steps {
                sh '''
                    echo $DOCKER_HUB_CREDENTIALS_PSW | docker login -u $DOCKER_HUB_CREDENTIALS_USR --password-stdin
                    docker push $BACKEND_IMAGE:${BUILD_NUMBER}
                    docker push $BACKEND_IMAGE:latest
                    docker push $FRONTEND_IMAGE:${BUILD_NUMBER}
                    docker push $FRONTEND_IMAGE:latest
                    docker logout
                '''
            }
        }

        // ─────────────────────────────────────────
        // Terraform Init
        // ─────────────────────────────────────────
        stage('Terraform Init') {
            steps {
                dir("${TF_DIR}") {
                    sh '''
                        terraform init -input=false
                    '''
                }
            }
        }

        // ─────────────────────────────────────────
        // Terraform Plan
        // ─────────────────────────────────────────
        stage('Terraform Plan') {
    steps {
        dir("${TF_DIR}") {
            sh '''
                export TF_VAR_kubeconfig_path="$KUBECONFIG"
                terraform plan \
                  -var="image_tag=${BUILD_NUMBER}" \
                  -var="dockerhub_user=${DOCKERHUB_USER}" \
                  -out=tfplan
            '''
        }
    }
}

        // ─────────────────────────────────────────
        // 🚀 Terraform Apply
        // Déploie l'application sur le cluster Kubernetes
        // Remplace les anciens : kubectl apply -f K8s/*.yaml
        //                        kubectl set image deployment/...
        // ─────────────────────────────────────────
        stage('Terraform Apply') {
    steps {
        dir("${TF_DIR}") {
            sh '''
                export TF_VAR_kubeconfig_path="$KUBECONFIG"
                terraform apply -auto-approve tfplan
            '''
        }
    }
}

        // ─────────────────────────────────────────
        // ✅ Vérification du déploiement
        // ─────────────────────────────────────────
        stage('Verify Deployment') {
            steps {
                sh '''
                    echo "=== Pods en cours ==="
                    kubectl get pods -n $K8S_NAMESPACE

                    echo ""
                    echo "=== Services ==="
                    kubectl get services -n $K8S_NAMESPACE

                    echo ""
                    echo "=== Attente que les pods soient Ready ==="
                    kubectl rollout status deployment/portfolio-backend  -n $K8S_NAMESPACE --timeout=120s
                    kubectl rollout status deployment/portfolio-frontend -n $K8S_NAMESPACE --timeout=120s
                '''
            }
        }
    }

    // ─────────────────────────────────────────
    // Post-build : notifications email
    // ─────────────────────────────────────────
    post {
        success {
            emailext (
                subject: "[Jenkins] Build #${env.BUILD_NUMBER} — SUCCESS ✅",
                body: """Pipeline SUCCESS ✅

Job      : ${env.JOB_NAME}
Build    : #${env.BUILD_NUMBER}
Duration : ${currentBuild.durationString}

[Quality]
SonarQube : PASSED ✅
Report    : http://172.17.0.3:9000/dashboard?id=portfolio-project

[Artifacts]
Backend  : ${env.DOCKERHUB_USER}/portfolio-backend:${env.BUILD_NUMBER} pushed to Docker Hub
Frontend : ${env.DOCKERHUB_USER}/portfolio-frontend:${env.BUILD_NUMBER} pushed to Docker Hub

[Terraform]
Déploiement effectué via Terraform ✅
Image tag : ${env.BUILD_NUMBER}

[Kubernetes]
Pods     : kubectl get pods -n portfolio
Frontend : http://localhost:30080

[Console]
${env.BUILD_URL}console
""",
                to: "seye10bineta@gmail.com"
            )
        }

        failure {
            echo 'Pipeline échoué ❌ — Rollback en cours...'
            sh '''
                kubectl rollout undo deployment/portfolio-backend  -n portfolio || true
                kubectl rollout undo deployment/portfolio-frontend -n portfolio || true
            '''
            emailext (
                subject: "[Jenkins] Build #${env.BUILD_NUMBER} — FAILURE ❌",
                body: """Pipeline FAILURE ❌

Job      : ${env.JOB_NAME}
Build    : #${env.BUILD_NUMBER}
Duration : ${currentBuild.durationString}

Stage en échec : ${env.STAGE_NAME}

[Kubernetes]
Rollback automatique effectué vers la version précédente.

[Console]
${env.BUILD_URL}console
""",
                to: "seye10bineta@gmail.com"
            )
        }
    }
}
